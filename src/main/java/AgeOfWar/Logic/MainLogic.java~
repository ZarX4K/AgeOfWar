                    gameState = 2;
                    System.out.println("Game state changed to In--Game!");
                    music.stopMusic();
                    music.loadMusic("souboj1.wav");
                    music.playMusic();

                }
            }
        });
    }


    private void spawnKnight() {
        long currentTime = System.currentTimeMillis();
        if (currentTime - lastKnightSpawnTime >= SPAWN_DELAY) {
            Knight knight = new Knight(150, 800, 150, 150, "knight.png", "knight.png", "knight.png", 100, 20, 25, 1, true, false, 10);
            if (playerGold >= knight.priceBuy) {
                knights.add(knight);
                System.out.println("Knight spawned");
                playerGold -= knight.priceBuy;
                moving.moveKnight(knight, knights);
                lastKnightSpawnTime = currentTime; // Update last spawn time
            } else {
                System.out.println("Not enough gold to spawn the knight!");
            }
        } else {
            System.out.println("Wait for the spawn delay to finish!");
        }
    }
